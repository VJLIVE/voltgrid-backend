# -- Local development ------------------------------------------
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=voltgrid
DB_PORT=3306

# -- Production (Render + TiDB Cloud / any MySQL provider) ------
# TiDB Cloud gives you a DATABASE_URL in this format:
# DATABASE_URL=mysql://user:pass@host:4000/dbname?ssl-mode=REQUIRED
# Paste it as a single env var in Render's dashboard — it overrides the vars above.

DATABASE_URL=

JWT_SECRET=change_me_to_a_strong_random_secret

# Your Vercel frontend URL (update after deploying frontend)
FRONTEND_URL=http://localhost:5173

PORT=3000
